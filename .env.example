# ─────────────────────────────────────────────────────────────
# DocuMind configuration. Copy to `.env` and fill in.
# Defaults are fully offline: hash embeddings, in-memory store,
# stub LLM, identity re-ranker — runs with zero external services.
# ─────────────────────────────────────────────────────────────

# Embeddings: hash | openai | cohere
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=256
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=
COHERE_EMBEDDING_MODEL=embed-english-v3.0

# Re-ranker (uses Cohere when COHERE_API_KEY is set, else identity)
RERANK_ENABLED=true
COHERE_RERANK_MODEL=rerank-english-v3.0

# Answer LLM: stub | anthropic | openai
LLM_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
TEMPERATURE=0.1
MAX_TOKENS=1024

# Vector store: memory | pgvector
VECTOR_STORE=memory
DATABASE_URL=postgresql://documind:documind@localhost:5432/documind
TABLE_NAME=documind_chunks
# For the memory store: persist to disk so `documind ingest` and `documind query`
# (separate processes) share data. Leave blank for in-process only.
MEMORY_PERSIST_PATH=.documind/store.json

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
CANDIDATE_POOL=20
TOP_K=5
